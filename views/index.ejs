<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="description" content="Solve logic, math, and word brain teasers in the browser. Instant feedback, hints, leaderboard, and completion stats." />
  <meta name="theme-color" content="#1a2332" />
  <title><%= pageTitle || 'Brain Teaser Hub' %></title>
  <link rel="stylesheet" href="/css/main.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/axios@1.7.9/dist/axios.min.js"></script>
</head>
<body<% if (typeof challenge !== 'undefined' && challenge && challenge.id) { %> class="is-challenge-route"<% } %>>
  <%- include('partials/navbar', { navActive: navActive || 'home' }) %>

  <main class="layout" id="main-content">
    <section class="panel puzzle-panel" aria-labelledby="puzzle-heading">
      <h2 id="puzzle-heading">Current puzzle</h2>

      <% if (typeof challenge !== 'undefined' && challenge && challenge.id) { %>
      <p class="challenge-banner" role="status">
        You’re solving a <strong>shared challenge</strong>. Send this puzzle to a friend with <strong>Copy challenge link</strong> below, or go back to <a href="/">random puzzles</a>.
      </p>
      <% } %>

      <div class="filters">
        <label>
          Type
          <select id="filter-type">
            <option value="">Any</option>
            <option value="logic">Logic</option>
            <option value="math">Math</option>
            <option value="word">Word</option>
          </select>
        </label>
        <label>
          Difficulty
          <select id="filter-difficulty">
            <option value="">Any</option>
            <option value="easy">Easy</option>
            <option value="medium">Medium</option>
            <option value="hard">Hard</option>
          </select>
        </label>
        <button type="button" class="btn btn-secondary" id="btn-reset-seen" title="Show puzzles you may have seen again">Reset seen</button>
      </div>

      <article class="puzzle-card" id="puzzle-card">
        <p class="puzzle-loading" id="puzzle-loading">Loading a puzzle…</p>
        <div class="puzzle-body hidden" id="puzzle-body">
          <div class="badges">
            <span class="badge badge-type" id="badge-type" data-tooltip="Logic: deduction and riddles. Math: numbers and patterns. Word: language twists.">—</span>
            <span class="badge badge-difficulty" id="badge-difficulty" data-tooltip="Easy: quick wins. Medium: think a bit. Hard: bring coffee.">—</span>
            <span class="badge badge-points" id="badge-points">— pts</span>
          </div>
          <p class="puzzle-question" id="puzzle-question"></p>
          <div class="hint-stack" id="hint-stack" aria-live="polite"></div>
          <div class="answer-row">
            <label class="sr-only" for="answer-input">Your answer</label>
            <input type="text" id="answer-input" autocomplete="off" placeholder="Type your answer" />
            <button type="button" class="btn btn-primary" id="btn-submit">Submit</button>
          </div>
          <div class="actions-row">
            <button type="button" class="btn btn-hint hidden" id="btn-hint" title="Each hint reduces your score">
              <span class="hint-icon" aria-hidden="true">?</span> Hint
            </button>
            <button type="button" class="btn btn-secondary" id="btn-new">New puzzle</button>
            <button type="button" class="btn btn-secondary btn-share hidden" id="btn-share-challenge" title="Copy a link so others get this same puzzle">
              Copy challenge link
            </button>
          </div>
          <p class="share-feedback hidden" id="share-feedback" role="status" aria-live="polite"></p>
          <p class="feedback" id="feedback" role="status"></p>
        </div>
      </article>

      <div class="username-row">
        <label for="username">Display name (leaderboard)</label>
        <input type="text" id="username" maxlength="32" placeholder="Anonymous" autocomplete="nickname" />
      </div>
    </section>

    <aside class="panel side-panel">
      <section class="leaderboard-block" id="leaderboard" aria-labelledby="lb-heading" tabindex="-1">
        <h2 id="lb-heading">Leaderboard</h2>
        <div class="leaderboard-scroll">
        <table class="leaderboard">
          <thead>
            <tr><th>#</th><th>Player</th><th>Score</th></tr>
          </thead>
          <tbody id="leaderboard-body">
            <% leaderboard.forEach(function (row, i) { %>
              <tr class="<%= i === 0 ? 'top-rank' : '' %>">
                <td><%= i + 1 %></td>
                <td><%= row.username %></td>
                <td><%= row.totalScore %></td>
              </tr>
            <% }); %>
            <% if (!leaderboard.length) { %>
              <tr><td colspan="3">No scores yet — be first!</td></tr>
            <% } %>
          </tbody>
        </table>
        </div>
      </section>

      <section class="stats-block" aria-labelledby="stats-heading">
        <h2 id="stats-heading">Completion stats</h2>
        <div class="charts">
          <div class="chart-wrap">
            <h3>By type</h3>
            <div class="chart-canvas-host chart-canvas-host--pie"><canvas id="chart-type"></canvas></div>
          </div>
          <div class="chart-wrap">
            <h3>By difficulty</h3>
            <div class="chart-canvas-host"><canvas id="chart-difficulty"></canvas></div>
          </div>
          <div class="chart-wrap chart-wide">
            <h3>Correct vs wrong guesses (global)</h3>
            <div class="chart-canvas-host chart-canvas-host--wide"><canvas id="chart-guess"></canvas></div>
          </div>
        </div>
      </section>
    </aside>
  </main>

  <%- include('partials/footer') %>

  <script id="initial-stats" type="application/json"><%- JSON.stringify(stats) %></script>
  <script id="page-config" type="application/json"><%- JSON.stringify({
    challengePuzzleId: (typeof challenge !== 'undefined' && challenge && challenge.id) ? challenge.id : null,
    isChallengeRoute: !!(typeof challenge !== 'undefined' && challenge && challenge.id),
  }) %></script>
  <script src="/js/app.js"></script>
</body>
</html>
